# DeCloud CLI Dashboard — environment configuration
# Copy to .env and fill in your values. Never commit .env to git.

# Orchestrator API (required)
DECLOUD_URL=https://orchestrator.decloud.io
DECLOUD_TOKEN=your-jwt-token-here

# Node Agent API (optional — enables node-only mode)
DECLOUD_NODE_URL=http://localhost:5100

# Dashboard behaviour (optional)
DECLOUD_REFRESH_INTERVAL=5      # seconds between auto-refresh
DECLOUD_LOG_LINES=200           # max log tail lines
DECLOUD_DEFAULT_REGION=         # pre-select a region filter (leave blank for all)
