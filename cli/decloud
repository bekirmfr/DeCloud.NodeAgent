# ============================================================================
# DASHBOARD COMMAND
# ============================================================================

cmd_dashboard() {
    local shim="/usr/local/bin/decloud-dashboard"

    if [[ ! -x "$shim" ]]; then
        echo ""
        log_error "Dashboard not installed."
        echo ""
        log_info "Run the installer first:"
        log_info "  bash /opt/decloud/DeCloud.NodeAgent/cli/dashboard/install-dashboard.sh"
        echo ""
        exit $EXIT_ERROR
    fi

    exec "$shim" "$@"
}

# ============================================================================
# COMMAND ROUTER
# ============================================================================

main() {
    # Global flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --debug)         export DEBUG=1; shift ;;
            -h|--help|help)  cmd_help;  exit $EXIT_SUCCESS ;;
            -v|--version)    cmd_version; exit $EXIT_SUCCESS ;;
            -*)
                log_error "Unknown option: $1"
                echo "Run '$SCRIPT_NAME --help' for usage"
                exit $EXIT_USAGE
                ;;
            *) break ;;
        esac
    done

    if [[ $# -eq 0 ]]; then
        cmd_help; exit $EXIT_USAGE
    fi

    local command="$1"; shift

    case "$command" in
        install)      cmd_install    "$@" ;;
        update)       cmd_update     "$@" ;;
        pull)         cmd_pull       "$@" ;;
        uninstall)    cmd_remove     "$@" ;;
        register)     cmd_register   "$@" ;;
        login)        cmd_login      "$@" ;;
        logout)       cmd_logout     "$@" ;;
        settings)     cmd_settings   "$@" ;;
        configure)    cmd_configure  "$@" ;; 
        status)       cmd_status     "$@" ;;
        info)         cmd_info       "$@" ;;
        resources)    cmd_resources  "$@" ;;
        heartbeat)    cmd_heartbeat  "$@" ;;
        performance|perf) cmd_performance "$@" ;;
        capacity|cap) cmd_capacity   "$@" ;;
        config)       cmd_node_config "$@" ;;
        node)         cmd_node_summary "$@" ;;
        evaluate|eval) cmd_evaluate  "$@" ;;
        vm)
            if [[ $# -eq 0 ]]; then
                log_error "VM subcommand required"
                echo "Usage: $SCRIPT_NAME vm <list|info|cleanup>"
                exit $EXIT_USAGE
            fi
            local vm_cmd="$1"; shift
            case "$vm_cmd" in
                list|ls)               cmd_vm_list              "$@" ;;
                info|show)             cmd_vm_info              "$@" ;;
                cleanup|clean|delete|rm) cmd_vm_cleanup         "$@" ;;
                reboot|hard-reboot)    cmd_vm_reboot            "$@" ;;
                migrate)               cmd_vm_migrate           "$@" ;;
                drain)                 cmd_vm_drain             "$@" ;;
                diagnose-system|sysdiag) cmd_vm_diagnose_system "$@" ;;
                *)
                    log_error "Unknown VM subcommand: $vm_cmd"
                    echo ""
                    echo "VM subcommands:"
                    echo "  list                    List all VMs on this node"
                    echo "  info <vm-id>            Show details for a specific VM"
                    echo "  cleanup <vm-id>         Destroy and remove a VM and its data"
                    echo "  reboot <vm-id>          Hard reboot a VM (virsh destroy+start)"
                    echo "                          Use when virsh reboot/ACPI is unresponsive"
                    echo "  migrate <vm-id>         Migrate a VM to another node"
                    echo "    --to <target-node-id>     primary migration target"
                    echo "  drain                   Drain the node of all VMs"
                    echo "     -to <target-node-id>     primary drain target"
                    echo "  diagnose-system         Check system VM health (WG mesh, libvirt,"
                    echo "                          DHT/BlockStore services, relay connectivity)"
                    exit $EXIT_USAGE
                    ;;
            esac
            ;;
        start)        cmd_start      "$@" ;;
        stop)         cmd_stop       "$@" ;;
        restart)      cmd_restart    "$@" ;;
        reset)        cmd_reset      "$@" ;;
        logs)         cmd_logs       "$@" ;;
        diagnose|diag) cmd_diagnose  "$@" ;;
        test-api)     cmd_test_api   "$@" ;;
        relay)        cmd_relay      "$@" ;;
        wg)           cmd_wg         "$@" ;;
        dashboard)    cmd_dashboard  "$@" ;;
        version)      cmd_version ;;
        *)
            log_error "Unknown command: $command"
            echo "Run '$SCRIPT_NAME --help' for usage"
            exit $EXIT_USAGE
            ;;
    esac
}

# ============================================================================
# ENTRY POINT
# ============================================================================

main "$@"
