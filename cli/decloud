cmd_status() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent Status${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    # Authentication status
    echo -e "${BOLD}Authentication:${NC}"
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        local node_id wallet api_key
        node_id=$(grep "^NODE_ID="      "$CREDENTIALS_FILE" | cut -d= -f2 || echo "Unknown")
        wallet=$(grep  "^WALLET_ADDRESS=" "$CREDENTIALS_FILE" | cut -d= -f2 || echo "Unknown")
        api_key=$(grep "^API_KEY="      "$CREDENTIALS_FILE" | cut -d= -f2 || echo "Unknown")
        log_success "Authenticated"
        echo "  Node ID:  $node_id"
        echo "  Wallet:   $wallet"
        echo "  API Key:  ${api_key:0:20}..."
    else
        log_warn "Not authenticated"
        echo "  Run: sudo $SCRIPT_NAME register"
    fi
    echo ""

    # Service status
    echo -e "${BOLD}Service:${NC}"
    if check_service_running; then
        log_success "Running"
        local uptime
        uptime=$(systemctl show -p ActiveEnterTimestamp "$SERVICE_NAME" | cut -d= -f2)
        [[ -n "$uptime" ]] && echo "  Started:  $uptime"

        # Memory — only display if cgroup accounting is active (avoids confusing "[not set]")
        local memory
        memory=$(systemctl show -p MemoryCurrent "$SERVICE_NAME" | cut -d= -f2)
        if [[ "$memory" =~ ^[0-9]+$ ]]; then
            echo "  Memory:   $(human_bytes "$memory")"
        fi
    else
        log_warn "Not running"
        echo "  Start with: sudo systemctl start $SERVICE_NAME"
    fi
    echo ""

    # Health check
    echo -e "${BOLD}Health:${NC}"
    if check_service_running; then
        local health
        if health=$(api_get "/api/node/health" 2>/dev/null); then
            log_success "API responding"
        else
            log_warn "API not responding (service starting?)"
        fi
    else
        log_warn "Service not running"
    fi
    echo ""

    # VM count
    echo -e "${BOLD}Virtual Machines:${NC}"
    if [[ -f "$CREDENTIALS_FILE" ]] && check_service_running; then
        local vms total running
        if vms=$(api_get "/api/vms" 2>/dev/null); then
            total=$(echo "$vms"   | jq -r 'length' 2>/dev/null || echo "0")
            # VmState.Running = index 3 in the enum
            running=$(echo "$vms" | jq -r '[.[] | select(.state == 3)] | length' 2>/dev/null || echo "0")
            echo "  Total:    $total"
            echo "  Running:  $running"
        else
            echo "  Unable to fetch VM data"
        fi
    else
        echo "  Not available (not authenticated or service not running)"
    fi
    echo ""

    # Network status
    echo -e "${BOLD}Network:${NC}"
    if check_service_running && [[ -f "$CREDENTIALS_FILE" ]]; then
        local status internet orchestrator
        if status=$(api_get "/api/node/network/status" 2>/dev/null); then
            internet=$(echo    "$status" | jq -r '.isInternetReachable    // "unknown"' 2>/dev/null)
            orchestrator=$(echo "$status" | jq -r '.isOrchestratorReachable // "unknown"' 2>/dev/null)
            [[ "$internet"     == "true" ]] && log_success "Internet reachable"     || log_warn "Internet unreachable"
            [[ "$orchestrator" == "true" ]] && log_success "Orchestrator reachable" || log_warn "Orchestrator unreachable"
        fi
    else
        echo "  Not available"
    fi
    echo ""
}

