cmd_relay() {
    local subcmd="${1:-}"
    shift || true

    local relay_bin="/usr/local/bin/decloud-relay-nat"
    if [[ ! -x "$relay_bin" ]]; then
        log_error "Relay NAT manager not found at $relay_bin"
        log_info "Run 'sudo $SCRIPT_NAME update' to reinstall"
        exit $EXIT_ERROR
    fi

    case "$subcmd" in
        add|clean|show|status)
            exec "$relay_bin" "$subcmd" "$@"
            ;;
        "")
            log_error "Relay subcommand required"
            echo "Usage: $SCRIPT_NAME relay <add|clean|show>"
            exit $EXIT_USAGE
            ;;
        *)
            log_error "Unknown relay command: $subcmd"
            echo "Valid: add, clean, show"
            exit $EXIT_USAGE
            ;;
    esac
}

# ============================================================================
# WIREGUARD COMMANDS
# ============================================================================

cmd_wg() {
    local subcmd="${1:-}"
    shift || true

    if ! command -v wg &>/dev/null; then
        log_error "WireGuard not installed"
        exit $EXIT_ERROR
    fi

    case "$subcmd" in
        status)
            local interfaces
            interfaces=$(wg show interfaces 2>/dev/null)
            if [[ -z "$interfaces" ]]; then
                log_warn "No WireGuard interfaces active"
                echo ""
                echo "This is normal if the node agent hasn't assigned an interface yet."
                echo "Check: $SCRIPT_NAME logs -f | grep -i wireguard"
            else
                wg show
                echo ""
                log_success "Active interfaces: $interfaces"
            fi
            ;;
        interfaces)
            wg show interfaces 2>/dev/null || echo "No interfaces active"
            ;;
        show)
            local iface="${1:-}"
            if [[ -z "$iface" ]]; then
                log_error "Interface name required"
                echo "Usage: $SCRIPT_NAME wg show <interface>"
                echo ""
                echo "Available interfaces:"
                wg show interfaces 2>/dev/null || echo "  (none)"
                exit $EXIT_USAGE
            fi
            if ! wg show "$iface" &>/dev/null; then
                log_error "Interface '$iface' not found"
                echo "Available interfaces:"
                wg show interfaces 2>/dev/null || echo "  (none)"
                exit $EXIT_ERROR
            fi
            wg show "$iface"
            ;;
        "")
            # Default: show status
            cmd_wg status
            ;;
        *)
            log_error "Unknown wg command: $subcmd"
            echo "Valid: status, interfaces, show <interface>"
            exit $EXIT_USAGE
            ;;
    esac
}

