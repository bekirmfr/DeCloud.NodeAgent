cmd_vm_cleanup() {
    check_root

    local vm_id=""
    local all_flag=false
    local dry_run=false
    local force=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)     all_flag=true; shift ;;
            --dry-run) dry_run=true;  shift ;;
            --force)   force=true;    shift ;;
            -*)
                log_error "Unknown option: $1"
                echo "Usage: $SCRIPT_NAME vm cleanup [<vm-id>|--all] [--dry-run] [--force]"
                exit $EXIT_USAGE
                ;;
            *)
                if [[ -z "$vm_id" ]]; then vm_id="$1"; fi
                shift
                ;;
        esac
    done

    if ! $all_flag && [[ -z "$vm_id" ]]; then
        log_error "Specify a VM ID or --all"
        echo "Usage: $SCRIPT_NAME vm cleanup <vm-id>"
        echo "       $SCRIPT_NAME vm cleanup --all"
        exit $EXIT_USAGE
    fi

    if $all_flag && [[ -n "$vm_id" ]]; then
        log_error "Cannot use both --all and a VM ID"
        exit $EXIT_USAGE
    fi

    check_dependencies virsh

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  VM Cleanup${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    $dry_run && log_warn "DRY-RUN MODE — no changes will be made"

    if $all_flag; then
        _vm_cleanup_all "$dry_run" "$force"
    else
        _vm_cleanup_one "$vm_id" "$dry_run" "$force"
    fi
}

# Internal: clean up a single VM
_vm_cleanup_one() {
    local vm_id="$1" dry_run="$2" force="$3"

    # Check existence
    local vm_state
    vm_state=$(virsh domstate "$vm_id" 2>/dev/null || echo "not_found")

    if [[ "$vm_state" == "not_found" ]] && [[ ! -d "$VM_STORAGE_PATH/$vm_id" ]]; then
        log_error "VM not found in libvirt or storage: $vm_id"
        exit $EXIT_ERROR
    fi

    if ! $force; then
        read -rp "Delete VM '$vm_id' and all its data? This is IRREVERSIBLE. [y/N]: " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { log_info "Cancelled"; exit $EXIT_SUCCESS; }
    fi

    log_info "Cleaning up VM: $vm_id"

    if ! $dry_run; then
        virsh destroy  "$vm_id" 2>/dev/null || true
        virsh undefine "$vm_id" --remove-all-storage 2>/dev/null || true
        [[ -d "$VM_STORAGE_PATH/$vm_id" ]] && rm -rf "${VM_STORAGE_PATH:?}/${vm_id:?}" || true
    fi

    log_success "VM $vm_id cleaned up"
}

# Internal: clean up ALL VMs
_vm_cleanup_all() {
    local dry_run="$1" force="$2"

    local all_vms
    mapfile -t all_vms < <(virsh list --all --name 2>/dev/null | grep -v '^$' || true)

    if (( ${#all_vms[@]} == 0 )); then
        log_info "No VMs found in libvirt"
        return 0
    fi

    log_warn "Found ${#all_vms[@]} VM(s): ${all_vms[*]}"

    if ! $force; then
        read -rp "Delete ALL ${#all_vms[@]} VMs and their data? Type 'YES' to confirm: " confirm
        [[ "$confirm" == "YES" ]] || { log_info "Cancelled"; exit $EXIT_SUCCESS; }
    fi

    local success=0 failed=0
    for v in "${all_vms[@]}"; do
        log_info "Cleaning up: $v"
        if ! $dry_run; then
            virsh destroy  "$v" 2>/dev/null || true
            virsh undefine "$v" --remove-all-storage 2>/dev/null || true
            [[ -d "$VM_STORAGE_PATH/$v" ]] && rm -rf "${VM_STORAGE_PATH:?}/${v:?}" || true
        fi
        (( success++ ))
        log_success "  $v cleaned up"
    done

    echo ""
    log_success "Cleanup complete: $success VM(s) processed, $failed failed"
}

cmd_vm_reboot() {
    local vmId="${1:-}"
    [[ -z "$vmId" ]] && { log_error "Usage: decloud vm reboot <vm-id>"; exit $EXIT_USAGE; }

    log_info "Hard rebooting VM $vmId (virsh destroy + start)..."
    local response http_code
    response=$(curl -s -w "\n%{http_code}" \
        -X POST "${NODE_AGENT_URL}/api/vms/${vmId}/hard-reboot" \
        -H "X-API-Key: $(get_api_key)" 2>/dev/null)
    http_code=$(echo "$response" | tail -1)
    body=$(echo "$response" | head -n -1)

    if [[ "$http_code" == "200" ]]; then
        log_success "VM $vmId hard rebooted — services will restart in ~3 minutes"
    else
        log_error "Hard reboot failed (HTTP $http_code)"
        echo "$body" | jq -r '.error // .' 2>/dev/null || echo "$body"
        exit $EXIT_ERROR
    fi
}

cmd_vm_diagnose_system() {
    echo ""
    echo -e "${BOLD}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  System VM Diagnostics${NC}"
    echo -e "${BOLD}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    local api_key; api_key=$(get_api_key)

    # ── Obligations ──────────────────────────────────────────────────────────
    echo -e "${BOLD}Obligations:${NC}"
    local obligations
    obligations=$(curl -sf --max-time 5 \
        -H "X-API-Key: $api_key" \
        "${NODE_AGENT_URL}/api/obligations" 2>/dev/null || echo "")

    if [[ -z "$obligations" ]]; then
        log_error "  Could not reach NodeAgent obligation endpoint"
    else
        echo "$obligations" | jq -r '
            .obligations[] |
            "  \(.roleName)\t Status: \(.statusName)\t VM: \(.vmId[0:8])..."
        ' 2>/dev/null || echo "$obligations"
    fi

    echo ""

    # ── VM states ─────────────────────────────────────────────────────────────
    echo -e "${BOLD}System VM States:${NC}"
    local vms
    vms=$(curl -sf --max-time 5 \
        -H "X-API-Key: $api_key" \
        "${NODE_AGENT_URL}/api/vms" 2>/dev/null || echo "")

    if [[ -n "$vms" ]]; then
        echo "$vms" | jq -r '
            .[] | select(.spec.vmType == 6 or .spec.vmType == 7 or .spec.vmType == 8) |
            "  \(.name)\t state=\(.state)\t heartbeat=\(.lastHeartbeat)"
        ' 2>/dev/null || true
    fi

    echo ""

    # ── WireGuard mesh ────────────────────────────────────────────────────────
    echo -e "${BOLD}WireGuard Relay Tunnel (host):${NC}"
    if wg show wg-relay &>/dev/null 2>&1; then
        local handshake_ago
        handshake_ago=$(wg show wg-relay latest-handshakes 2>/dev/null | awk '{print $2}')
        local now; now=$(date +%s)
        if [[ -n "$handshake_ago" && "$handshake_ago" != "0" ]]; then
            local age=$(( now - handshake_ago ))
            if (( age < 150 )); then
                log_success "  wg-relay: handshake ${age}s ago ✓"
            else
                log_warn "  wg-relay: handshake ${age}s ago (stale — expected <150s)"
            fi
        else
            log_error "  wg-relay: no handshake yet"
        fi
    else
        log_error "  wg-relay interface not found"
    fi

    echo ""

    # ── libvirt network ───────────────────────────────────────────────────────
    echo -e "${BOLD}libvirt Network:${NC}"
    if virsh net-info default &>/dev/null 2>&1; then
        local net_active
        net_active=$(virsh net-info default 2>/dev/null | grep "Active:" | awk '{print $2}')
        if [[ "$net_active" == "yes" ]]; then
            log_success "  libvirt default network: active ✓"
        else
            log_error "  libvirt default network: INACTIVE"
        fi
    else
        log_error "  Could not query libvirt default network"
    fi

    echo ""

    # ── System VM health endpoints ────────────────────────────────────────────
    echo -e "${BOLD}VM Service Health (via NodeAgent proxy):${NC}"
    if [[ -n "$vms" ]]; then
        echo "$vms" | jq -r '
            .[] | select(.spec.vmType == 6 or .spec.vmType == 7 or .spec.vmType == 8) |
            "\(.vmId) \(.name) \(.spec.ipAddress // "")"
        ' 2>/dev/null | while read -r vmid name ip; do
            if [[ -z "$ip" ]]; then
                echo -e "  $name: ${YELLOW}no IP assigned${NC}"
                continue
            fi
            local code
            code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 3 \
                -H "X-API-Key: $api_key" \
                "${NODE_AGENT_URL}/api/proxy/${vmid}/80/health" 2>/dev/null || echo "ERR")
            if [[ "$code" == "200" ]]; then
                log_success "  $name ($ip): HTTP 200 ✓"
            else
                log_error "  $name ($ip): HTTP $code"
            fi
        done
    fi

    echo ""
    echo -e "${BOLD}Tip:${NC} to hard reboot a zombie VM: ${BOLD}sudo decloud vm reboot <vm-id>${NC}"
    echo ""
}

