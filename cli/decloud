cmd_install() {
    check_root

    if [[ $# -eq 0 ]]; then
        log_error "No install parameters provided"
        echo ""
        echo "Usage: sudo $SCRIPT_NAME install --orchestrator <url> --wallet <address> [options]"
        echo ""
        echo "Options:"
        echo "  --orchestrator <url>     Orchestrator URL (required)"
        echo "  --wallet <address>       Node operator wallet address (required)"
        echo "  --gpu                    Enable GPU support"
        echo "  (any other flags are passed through to install.sh)"
        echo ""
        echo "After install, configure your node:"
        echo "  sudo $SCRIPT_NAME configure --country TR --region eu-east --name MyNode"
        echo "  sudo $SCRIPT_NAME register"
    fi

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent — Install${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    # Locate install script
    local install_script
    if ! install_script=$(find_install_script); then
        log_error "Node agent install.sh not found"
        log_info "Searched in:"
        log_info "  $SCRIPT_DIR/install.sh"
        log_info "  /opt/decloud/DeCloud.NodeAgent/install.sh"
        log_info "  /opt/decloud/install.sh"
        exit $EXIT_ERROR
    fi

    log_info "Using install script: $install_script"
    log_info "Parameters: $*"
    echo ""

    # Change to a safe CWD before launching install.sh.
    # The caller may be sitting in /opt/decloud/DeCloud.NodeAgent which install.sh
    # is about to delete and re-clone.  Every subshell bash spawns inherits CWD;
    # if that directory is gone, getcwd() fails and floods output with:
    #   "job-working-directory: error retrieving current directory: ..."
    cd / 2>/dev/null || true

    # Execute install
    bash "$install_script" "$@"
    local exit_code=$?

    if (( exit_code == 0 )); then
        echo ""
        log_success "Installation complete"
        log_info "Register now: sudo $SCRIPT_NAME register"
    else
        log_error "Installation failed (exit code $exit_code)"
        exit $exit_code
    fi
}

cmd_update() {
    check_root
 
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent — Update${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
 
    local -a SAVED_PARAMS
    load_install_params
 
    log_info "Re-running install with saved parameters:"
    for p in "${SAVED_PARAMS[@]}"; do
        log_info "  $p"
    done
    echo ""
 
    # Hybrid: try GitHub Release first, fall back to on-disk copy.
    local install_script=""
    local cleanup_path=""
 
    log_info "Fetching latest install.sh from GitHub Release..."
    if install_script=$(fetch_release_script "install.sh"); then
        cleanup_path="$install_script"
        log_success "Using latest install.sh from GitHub: $install_script"
    else
        log_warn "Could not fetch install.sh from GitHub (offline or unreachable)"
        if install_script=$(find_install_script); then
            log_info "Falling back to local copy: $install_script"
        else
            log_error "Could not fetch install.sh from GitHub and no local copy was found"
            log_info "Re-seed manually:"
            log_info "  sudo curl -fsSL https://github.com/bekirmfr/DeCloud.NodeAgent/releases/latest/download/install.sh \\"
            log_info "    -o /usr/local/share/decloud/install.sh"
            log_info "  sudo chmod 755 /usr/local/share/decloud/install.sh"
            exit $EXIT_ERROR
        fi
    fi
 
    echo ""
    cd / 2>/dev/null || true
    bash "$install_script" "${SAVED_PARAMS[@]}"
    local exit_code=$?
 
    [ -n "$cleanup_path" ] && rm -f "$cleanup_path"
 
    if (( exit_code == 0 )); then
        echo ""
        log_success "Update complete"
    else
        log_error "Update failed (exit code $exit_code)"
        exit $exit_code
    fi
}

# ============================================================================
# PULL COMMAND  —  git pull with auto branch detection
#            cd /opt/decloud/DeCloud.NodeAgent && dotnet publish ... && systemctl restart
# ============================================================================
cmd_pull() {
    check_root
    check_dependencies git

    if [[ ! -d "$REPO_DIR/.git" ]]; then
        log_error "Repository not found at $REPO_DIR"
        exit $EXIT_ERROR
    fi

    # Detect current branch — no hardcoded "main"
    local branch
    branch=$(git -C "$REPO_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")

    log_info "Pulling $REPO_DIR ($branch)..."

    # cd to / so getcwd never fails if caller is inside the repo dir
    cd / 2>/dev/null || true

    git -C "$REPO_DIR" pull origin "$branch"
}

cmd_remove() {
    check_root
 
    local -a passthrough_args=()
    while [[ $# -gt 0 ]]; do
        passthrough_args+=("$1")
        shift
    done
 
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent — Uninstall${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
 
    # Same hybrid pattern as cmd_update: prefer the latest uninstall.sh
    # (so cleanup logic always knows about the most recent layout),
    # fall back to on-disk copy when offline.
    local uninstall_script=""
    local cleanup_path=""
 
    log_info "Fetching latest uninstall.sh from GitHub Release..."
    if uninstall_script=$(fetch_release_script "uninstall.sh"); then
        cleanup_path="$uninstall_script"
        log_success "Using latest uninstall.sh from GitHub: $uninstall_script"
    else
        log_warn "Could not fetch uninstall.sh from GitHub (offline or unreachable)"
        if uninstall_script=$(find_uninstall_script); then
            log_info "Falling back to local copy: $uninstall_script"
        else
            log_error "Could not fetch uninstall.sh from GitHub and no local copy was found"
            log_info "Download manually:"
            log_info "  sudo curl -fsSL https://github.com/bekirmfr/DeCloud.NodeAgent/releases/latest/download/uninstall.sh \\"
            log_info "    -o /usr/local/share/decloud/uninstall.sh"
            log_info "  sudo chmod 755 /usr/local/share/decloud/uninstall.sh"
            log_info "  sudo /usr/local/share/decloud/uninstall.sh"
            exit $EXIT_ERROR
        fi
    fi
 
    echo ""
    cd / 2>/dev/null || true
    bash "$uninstall_script" "${passthrough_args[@]}"
    local exit_code=$?
 
    [ -n "$cleanup_path" ] && rm -f "$cleanup_path"
 
    exit $exit_code
}


