#!/usr/bin/env bash

#═══════════════════════════════════════════════════════════════════════════
# DeCloud Node Agent CLI
# Version: 2.0.0
#
# A unified CLI tool for managing DeCloud node agent operations.
# Inspired by: docker, kubectl, systemctl
#
# Usage:
#   decloud <command> [options]
#   decloud --help
#═══════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ============================================================================
# GLOBAL CONSTANTS
# ============================================================================

readonly VERSION="2.0.0"
readonly SCRIPT_NAME="$(basename "$0")"
# Use readlink -f to resolve the script's real directory without relying on
# the calling shell's CWD via getcwd().  The cd+pwd idiom breaks when the
# shell's CWD has been deleted (e.g. /opt/decloud/DeCloud.NodeAgent wiped by
# 'decloud update'), producing:
#   "getcwd: cannot access parent directories: No such file or directory"
readonly SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

# Configuration paths
readonly CONFIG_DIR="/etc/decloud"
readonly CREDENTIALS_FILE="$CONFIG_DIR/credentials"
readonly PENDING_AUTH_FILE="$CONFIG_DIR/pending-auth"
readonly INSTALL_PARAMS_FILE="$CONFIG_DIR/install-params"
readonly VM_STORAGE_PATH="/var/lib/decloud/vms"
readonly BACKUP_PATH="/var/backups/decloud"
readonly LOG_DIR="/var/log/decloud"
readonly LOG_FILE="$LOG_DIR/nodeagent.log"

# Node agent source and publish paths (must match install.sh)
readonly REPO_DIR="/opt/decloud/DeCloud.NodeAgent"
readonly PUBLISH_DIR="/opt/decloud/publish"

# Service name
readonly SERVICE_NAME="decloud-node-agent"

# Node agent API (overridable via env)
NODE_AGENT_URL="${NODE_AGENT_URL:-http://localhost:5100}"

# VmState enum — matches VmState in VmModels.cs (index order)
readonly -a VM_STATE_NAMES=(
    "Pending"    # 0
    "Creating"   # 1
    "Starting"   # 2
    "Running"    # 3
    "Paused"     # 4
    "Stopping"   # 5
    "Stopped"    # 6
    "Failed"     # 7
    "NotFound"   # 8
    "Deleted"    # 9
    "Migrating"  # 10
)

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly NC='\033[0m'

# Exit codes
readonly EXIT_SUCCESS=0
readonly EXIT_ERROR=1
readonly EXIT_USAGE=2
readonly EXIT_NO_AUTH=3
readonly EXIT_API_ERROR=4

# ============================================================================
# LOGGING FUNCTIONS
# ============================================================================

log_info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[✓]${NC} $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
log_debug()   { [[ "${DEBUG:-0}" == "1" ]] && echo -e "${CYAN}[DEBUG]${NC} $*" >&2 || true; }

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "This command requires root privileges"
        log_info "Please run with: sudo $SCRIPT_NAME $*"
        exit $EXIT_ERROR
    fi
}

check_dependencies() {
    local missing_deps=()
    for cmd in "$@"; do
        if ! command -v "$cmd" &>/dev/null; then
            missing_deps+=("$cmd")
        fi
    done
    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        log_error "Missing required dependencies: ${missing_deps[*]}"
        return 1
    fi
    return 0
}

check_service_running() {
    if ! systemctl is-active --quiet "$SERVICE_NAME"; then
        return 1
    fi
    return 0
}

check_authenticated() {
    if [[ ! -f "$CREDENTIALS_FILE" ]]; then
        log_error "Node not authenticated. Run: sudo $SCRIPT_NAME login"
        exit $EXIT_NO_AUTH
    fi
}

get_node_id() {
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        grep "^NODE_ID=" "$CREDENTIALS_FILE" | cut -d= -f2 2>/dev/null || echo ""
    else
        echo ""
    fi
}

get_machine_id() {
    if [[ -f /etc/machine-id ]]; then
        cat /etc/machine-id
    else
        log_error "Cannot read /etc/machine-id"
        exit $EXIT_ERROR
    fi
}

# Convert VmState integer to human-readable name
vm_state_name() {
    local idx="${1:-}"
    if [[ "$idx" =~ ^[0-9]+$ ]] && [[ "$idx" -lt "${#VM_STATE_NAMES[@]}" ]]; then
        echo "${VM_STATE_NAMES[$idx]}"
    else
        echo "$idx"  # pass through if it's already a string or unknown
    fi
}

# Human-readable bytes
human_bytes() {
    local bytes="${1:-0}"
    if ! [[ "$bytes" =~ ^[0-9]+$ ]]; then echo "$bytes"; return; fi
    if   (( bytes >= 1073741824 )); then awk "BEGIN {printf \"%.1f GB\", $bytes/1073741824}"
    elif (( bytes >= 1048576 ));    then awk "BEGIN {printf \"%.1f MB\", $bytes/1048576}"
    elif (( bytes >= 1024 ));       then awk "BEGIN {printf \"%.1f KB\", $bytes/1024}"
    else echo "${bytes} B"; fi
}

# ============================================================================
# API FUNCTIONS
# ============================================================================

# Safe API call — never exits on curl error; returns 1 on failure.
# Outputs response body on stdout; HTTP code sent to stderr only in debug mode.
api_call() {
    local method="$1"
    local endpoint="$2"
    local data="${3:-}"
    local url="${NODE_AGENT_URL}${endpoint}"
    local http_code body tmp

    # Use a temp file so we can separate body from http_code without subshell +
    # set -e interaction from arithmetic on a non-numeric string.
    tmp=$(mktemp)

    if [[ -n "$data" ]]; then
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            -H "Content-Type: application/json" \
            -d "$data" \
            --connect-timeout 5 \
            "$url" 2>/dev/null
    else
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            --connect-timeout 5 \
            "$url" 2>/dev/null
    fi
    http_code=$?   # curl exit code first

    # Re-read actual HTTP code from curl's -w output (captured via $())
    # We need a different approach: write http_code to a separate tmp file.
    local code_file
    code_file=$(mktemp)

    if [[ -n "$data" ]]; then
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            -H "Content-Type: application/json" \
            -d "$data" \
            --connect-timeout 5 \
            "$url" 2>/dev/null > "$code_file" || true
    else
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            --connect-timeout 5 \
            "$url" 2>/dev/null > "$code_file" || true
    fi

    http_code=$(cat "$code_file" 2>/dev/null | tr -d '[:space:]' | head -c 3 || echo "0")
    body=$(cat "$tmp" 2>/dev/null || echo "")
    rm -f "$tmp" "$code_file"

    log_debug "API $method $url → HTTP $http_code"

    if [[ "$http_code" =~ ^[0-9]+$ ]] && (( http_code >= 200 && http_code < 300 )); then
        echo "$body"
        return 0
    else
        log_debug "API error (HTTP $http_code): $body"
        return 1
    fi
}

api_get()    { api_call "GET"    "$1"; }
api_post()   { api_call "POST"   "$1" "$2"; }
api_delete() { api_call "DELETE" "$1"; }

# ============================================================================
# INSTALL PARAMS HELPERS
# ============================================================================

# Save install parameters to /etc/decloud/install-params
save_install_params() {
    mkdir -p "$CONFIG_DIR"
    {
        echo "# DeCloud node install parameters — written by 'decloud install'"
        echo "# Used by 'decloud update' to re-run the install with the same settings."
        echo "# Generated: $(date '+%Y-%m-%d %H:%M:%S')"
        for arg in "$@"; do
            echo "$arg"
        done
    } > "$INSTALL_PARAMS_FILE"
    chmod 600 "$INSTALL_PARAMS_FILE"
    log_success "Install parameters saved to $INSTALL_PARAMS_FILE"
}

# Load install parameters from file into an array
load_install_params() {
    if [[ ! -f "$INSTALL_PARAMS_FILE" ]]; then
        log_error "No saved install parameters found at $INSTALL_PARAMS_FILE"
        log_info "Run 'sudo decloud install --orchestrator <url> ...' first"
        exit $EXIT_ERROR
    fi
    # Read non-comment, non-empty lines
    mapfile -t SAVED_PARAMS < <(grep -v '^#' "$INSTALL_PARAMS_FILE" | grep -v '^[[:space:]]*$')
}

# Find the node agent install.sh script
find_install_script() {
    local candidates=(
        "$SCRIPT_DIR/install.sh"
        "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/install.sh"
        "/opt/decloud/DeCloud.NodeAgent/install.sh"
        "/opt/decloud/install.sh"
        "/usr/local/share/decloud/install.sh"
    )
    for path in "${candidates[@]}"; do
        if [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    return 1
}

# ============================================================================
# AUTHENTICATION COMMANDS
# ============================================================================

cmd_login() {
    check_root

    # cli-decloud-node handles the full auth flow:
    #   wallet address prompt → signing message → QR code → sign.html URL
    #   → signature input → local verification → writes /etc/decloud/pending-auth as JSON
    # AuthenticationManager then reads that JSON and registers with the orchestrator,
    # writing /etc/decloud/credentials on success.
    local wallet_cli="/usr/local/bin/cli-decloud-node"
    if [[ ! -x "$wallet_cli" ]]; then
        log_error "Authentication CLI not found at $wallet_cli"
        log_info "Run 'sudo $SCRIPT_NAME update' to reinstall"
        exit $EXIT_ERROR
    fi

    # Ensure service is running so AuthenticationManager can pick up pending-auth
    if ! check_service_running; then
        log_warn "Node agent service is not running — starting it..."
        systemctl start "$SERVICE_NAME" || {
            log_error "Failed to start service"
            exit $EXIT_ERROR
        }
        sleep 2
    fi

    # Already authenticated?
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        local node_id; node_id=$(get_node_id)
        log_warn "Node is already authenticated (Node ID: $node_id)"
        read -rp "Re-authenticate? This will re-register the node. [y/N]: " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            log_info "Login cancelled"
            exit $EXIT_SUCCESS
        fi
        rm -f "$CREDENTIALS_FILE"
    fi

    # Remove any stale pending-auth before starting
    rm -f "$PENDING_AUTH_FILE"

    # ── Step 1: run cli-decloud-node login ──────────────────────────────────
    # This prompts for wallet, shows QR code, waits for signature,
    # verifies it locally, and writes the JSON pending-auth file.
    "$wallet_cli" login
    local cli_exit=$?

    if (( cli_exit != 0 )); then
        log_error "Authentication cancelled or failed"
        exit $EXIT_ERROR
    fi

    # Confirm the JSON pending-auth file was actually written
    if [[ ! -f "$PENDING_AUTH_FILE" ]]; then
        log_error "Pending auth file not written — authentication may have failed"
        exit $EXIT_ERROR
    fi

    # ── Step 2: wait for AuthenticationManager to complete registration ─────
    echo ""
    log_info "Waiting for node agent to complete registration..."
    echo ""

    local timeout=120
    local elapsed=0
    local interval=3

    while (( elapsed < timeout )); do
        if [[ -f "$CREDENTIALS_FILE" ]]; then
            local node_id; node_id=$(get_node_id)
            echo ""
            echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
            echo -e "${BOLD}  ✓ Registration Complete!${NC}"
            echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
            echo ""
            echo "  Node ID: $node_id"
            echo ""
            log_info "Run '$SCRIPT_NAME status' to check node status"
            echo ""
            return 0
        fi

        printf "  Waiting for agent registration... (%ds/%ds)\r" "$elapsed" "$timeout"
        sleep $interval
        (( elapsed += interval ))
    done

    echo ""
    log_error "Registration timed out after ${timeout}s"
    log_info "The signature was saved. Check agent logs to see why registration failed:"
    log_info "  $SCRIPT_NAME logs --journal -n 50"
    exit $EXIT_ERROR
}

cmd_logout() {
    check_root

    log_info "Logging out node..."

    local removed=0
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        rm -f "$CREDENTIALS_FILE"
        log_success "Credentials removed"
        (( removed++ ))
    fi
    if [[ -f "$PENDING_AUTH_FILE" ]]; then
        rm -f "$PENDING_AUTH_FILE"
        log_success "Pending auth removed"
        (( removed++ ))
    fi

    if (( removed == 0 )); then
        log_info "Node was not authenticated"
    else
        log_success "Node logged out"
        log_info "Re-authenticate with: sudo $SCRIPT_NAME login"
    fi
}

# ============================================================================
# INSTALL & UPDATE COMMANDS
# ============================================================================

cmd_install() {
    check_root

    if [[ $# -eq 0 ]]; then
        log_error "No install parameters provided"
        echo ""
        echo "Usage: sudo $SCRIPT_NAME install --orchestrator <url> --wallet <address> [options]"
        echo ""
        echo "Options passed directly to the node agent install.sh:"
        echo "  --orchestrator <url>     Orchestrator URL (required)"
        echo "  --wallet <address>       Node operator wallet address (required)"
        echo "  --region <region>        Node region (e.g. us-east-1)"
        echo "  --zone <zone>            Node availability zone (e.g. us-east-1-nyc-1a)"
        echo "  --name <name>            Node display name"
        echo "  --gpu                    Enable GPU support"
        echo "  (any other flags are passed through to install.sh)"
        echo ""
        echo "Example:"
        echo "  sudo $SCRIPT_NAME install \\"
        echo "    --orchestrator https://decloud.stackfi.tech \\"
        echo "    --wallet 0x86b8... \\"
        echo "    --region us-east-1 \\"
        echo "    --zone us-east-1-nyc-1a \\"
        echo "    --name MyNode"
        exit $EXIT_USAGE
    fi

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent — Install${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    # Locate install script
    local install_script
    if ! install_script=$(find_install_script); then
        log_error "Node agent install.sh not found"
        log_info "Searched in:"
        log_info "  $SCRIPT_DIR/install.sh"
        log_info "  /opt/decloud/DeCloud.NodeAgent/install.sh"
        log_info "  /opt/decloud/install.sh"
        exit $EXIT_ERROR
    fi

    log_info "Using install script: $install_script"
    log_info "Parameters: $*"
    echo ""

    # Save parameters before running (so 'update' works even if install fails)
    save_install_params "$@"

    # Change to a safe CWD before launching install.sh.
    # The caller may be sitting in /opt/decloud/DeCloud.NodeAgent which install.sh
    # is about to delete and re-clone.  Every subshell bash spawns inherits CWD;
    # if that directory is gone, getcwd() fails and floods output with:
    #   "job-working-directory: error retrieving current directory: ..."
    cd / 2>/dev/null || true

    # Execute install
    bash "$install_script" "$@"
    local exit_code=$?

    if (( exit_code == 0 )); then
        echo ""
        log_success "Installation complete"
        log_info "Authenticate now: sudo $SCRIPT_NAME login"
    else
        log_error "Installation failed (exit code $exit_code)"
        exit $exit_code
    fi
}

cmd_update() {
    check_root

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent — Update${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    local -a SAVED_PARAMS
    load_install_params  # populates SAVED_PARAMS or exits

    log_info "Re-running install with saved parameters:"
    for p in "${SAVED_PARAMS[@]}"; do
        log_info "  $p"
    done
    echo ""

    # Locate install script
    local install_script
    if ! install_script=$(find_install_script); then
        log_error "Node agent install.sh not found"
        exit $EXIT_ERROR
    fi

    log_info "Using install script: $install_script"
    echo ""

    # Change to / before launching install.sh — same reason as cmd_install:
    # the current directory may be the repo clone that install.sh is about to wipe.
    cd / 2>/dev/null || true

    bash "$install_script" "${SAVED_PARAMS[@]}"
    local exit_code=$?

    if (( exit_code == 0 )); then
        echo ""
        log_success "Update complete"
    else
        log_error "Update failed (exit code $exit_code)"
        exit $exit_code
    fi
}

# ============================================================================
# PULL COMMAND  —  git pull with auto branch detection
#            cd /opt/decloud/DeCloud.NodeAgent && dotnet publish ... && systemctl restart
# ============================================================================
cmd_pull() {
    check_root
    check_dependencies git

    if [[ ! -d "$REPO_DIR/.git" ]]; then
        log_error "Repository not found at $REPO_DIR"
        exit $EXIT_ERROR
    fi

    # Detect current branch — no hardcoded "main"
    local branch
    branch=$(git -C "$REPO_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")

    log_info "Pulling $REPO_DIR ($branch)..."

    # cd to / so getcwd never fails if caller is inside the repo dir
    cd / 2>/dev/null || true

    git -C "$REPO_DIR" pull origin "$branch"
}

cmd_remove() {
    check_root

    local -a passthrough_args=()
    while [[ $# -gt 0 ]]; do
        passthrough_args+=("$1")
        shift
    done

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent — Uninstall${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    local uninstall_script
    uninstall_script=$(dirname "$(find_install_script 2>/dev/null || echo "")")/uninstall.sh

    if [[ ! -f "$uninstall_script" ]]; then
        # Fall back to repo location
        uninstall_script="/opt/decloud/DeCloud.NodeAgent/uninstall.sh"
    fi

    if [[ ! -f "$uninstall_script" ]]; then
        log_error "uninstall.sh not found"
        log_info "Download from: https://github.com/bekirmfr/DeCloud.NodeAgent/raw/main/uninstall.sh"
        exit $EXIT_ERROR
    fi

    cd / 2>/dev/null || true
    bash "$uninstall_script" "${passthrough_args[@]}"
}

# ============================================================================
# STATUS & INFO COMMANDS
# ============================================================================

cmd_status() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent Status${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    # Authentication status
    echo -e "${BOLD}Authentication:${NC}"
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        local node_id wallet api_key
        node_id=$(grep "^NODE_ID="      "$CREDENTIALS_FILE" | cut -d= -f2 || echo "Unknown")
        wallet=$(grep  "^WALLET_ADDRESS=" "$CREDENTIALS_FILE" | cut -d= -f2 || echo "Unknown")
        api_key=$(grep "^API_KEY="      "$CREDENTIALS_FILE" | cut -d= -f2 || echo "Unknown")
        log_success "Authenticated"
        echo "  Node ID:  $node_id"
        echo "  Wallet:   $wallet"
        echo "  API Key:  ${api_key:0:20}..."
    else
        log_warn "Not authenticated"
        echo "  Run: sudo $SCRIPT_NAME login"
    fi
    echo ""

    # Service status
    echo -e "${BOLD}Service:${NC}"
    if check_service_running; then
        log_success "Running"
        local uptime
        uptime=$(systemctl show -p ActiveEnterTimestamp "$SERVICE_NAME" | cut -d= -f2)
        [[ -n "$uptime" ]] && echo "  Started:  $uptime"

        # Memory — only display if cgroup accounting is active (avoids confusing "[not set]")
        local memory
        memory=$(systemctl show -p MemoryCurrent "$SERVICE_NAME" | cut -d= -f2)
        if [[ "$memory" =~ ^[0-9]+$ ]]; then
            echo "  Memory:   $(human_bytes "$memory")"
        fi
    else
        log_warn "Not running"
        echo "  Start with: sudo systemctl start $SERVICE_NAME"
    fi
    echo ""

    # Health check
    echo -e "${BOLD}Health:${NC}"
    if check_service_running; then
        local health
        if health=$(api_get "/api/node/health" 2>/dev/null); then
            log_success "API responding"
        else
            log_warn "API not responding (service starting?)"
        fi
    else
        log_warn "Service not running"
    fi
    echo ""

    # VM count
    echo -e "${BOLD}Virtual Machines:${NC}"
    if [[ -f "$CREDENTIALS_FILE" ]] && check_service_running; then
        local vms total running
        if vms=$(api_get "/api/vms" 2>/dev/null); then
            total=$(echo "$vms"   | jq -r 'length' 2>/dev/null || echo "0")
            # VmState.Running = index 3 in the enum
            running=$(echo "$vms" | jq -r '[.[] | select(.state == 3)] | length' 2>/dev/null || echo "0")
            echo "  Total:    $total"
            echo "  Running:  $running"
        else
            echo "  Unable to fetch VM data"
        fi
    else
        echo "  Not available (not authenticated or service not running)"
    fi
    echo ""

    # Network status
    echo -e "${BOLD}Network:${NC}"
    if check_service_running && [[ -f "$CREDENTIALS_FILE" ]]; then
        local status internet orchestrator
        if status=$(api_get "/api/node/network/status" 2>/dev/null); then
            internet=$(echo    "$status" | jq -r '.isInternetReachable    // "unknown"' 2>/dev/null)
            orchestrator=$(echo "$status" | jq -r '.isOrchestratorReachable // "unknown"' 2>/dev/null)
            [[ "$internet"     == "true" ]] && log_success "Internet reachable"     || log_warn "Internet unreachable"
            [[ "$orchestrator" == "true" ]] && log_success "Orchestrator reachable" || log_warn "Orchestrator unreachable"
        fi
    else
        echo "  Not available"
    fi
    echo ""
}

cmd_info() {
    check_authenticated

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Node Information${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    if ! check_service_running; then
        log_error "Service not running"; exit $EXIT_ERROR
    fi

    local node_info
    if node_info=$(api_get "/api/node" 2>/dev/null); then
        echo "$node_info" | jq -C '.' 2>/dev/null || echo "$node_info"
    else
        log_error "Failed to fetch node information"; exit $EXIT_API_ERROR
    fi
    echo ""
}

cmd_resources() {
    check_authenticated

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Resource Information${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    if ! check_service_running; then
        log_error "Service not running"; exit $EXIT_ERROR
    fi

    for resource in cpu memory storage network; do
        echo -e "${BOLD}${resource^}:${NC}"
        local result
        if result=$(api_get "/api/node/$resource" 2>/dev/null); then
            echo "$result" | jq -C '.' 2>/dev/null || echo "$result"
        else
            log_warn "Could not fetch $resource info"
        fi
        echo ""
    done
}

cmd_heartbeat() {
    check_authenticated
    if ! check_service_running; then
        log_error "Service not running"; exit $EXIT_ERROR
    fi
    local hb
    if hb=$(api_get "/api/node/heartbeat" 2>/dev/null); then
        echo "$hb" | jq -C '.' 2>/dev/null || echo "$hb"
    else
        log_error "Failed to fetch heartbeat data"; exit $EXIT_API_ERROR
    fi
}

# ============================================================================
# ORCHESTRATOR DIAGNOSTIC COMMANDS
# ============================================================================

cmd_performance() {
    check_authenticated
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Node Performance Evaluation${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
