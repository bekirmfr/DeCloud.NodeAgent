#!/usr/bin/env bash

#═══════════════════════════════════════════════════════════════════════════
# DeCloud Node Agent CLI
# Version: 2.0.0
#
# A unified CLI tool for managing DeCloud node agent operations.
# Inspired by: docker, kubectl, systemctl
#
# Usage:
#   decloud <command> [options]
#   decloud --help
#═══════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ============================================================================
# GLOBAL CONSTANTS
# ============================================================================

readonly VERSION="2.0.0"
readonly SCRIPT_NAME="$(basename "$0")"
# Use readlink -f to resolve the script's real directory without relying on
# the calling shell's CWD via getcwd().  The cd+pwd idiom breaks when the
# shell's CWD has been deleted (e.g. /opt/decloud/DeCloud.NodeAgent wiped by
# 'decloud update'), producing:
#   "getcwd: cannot access parent directories: No such file or directory"
readonly SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

# Configuration paths
readonly CONFIG_DIR="/etc/decloud"
readonly CREDENTIALS_FILE="$CONFIG_DIR/credentials"
readonly PENDING_AUTH_FILE="$CONFIG_DIR/pending-auth"
readonly SETTINGS_FILE="$CONFIG_DIR/settings.json"
readonly VM_STORAGE_PATH="/var/lib/decloud/vms"
readonly BACKUP_PATH="/var/backups/decloud"
readonly LOG_DIR="/var/log/decloud"
readonly LOG_FILE="$LOG_DIR/nodeagent.log"

# Node agent source and publish paths (must match install.sh)
readonly REPO_DIR="/opt/decloud/DeCloud.NodeAgent"
readonly PUBLISH_DIR="/opt/decloud/publish"

# Service name
readonly SERVICE_NAME="decloud-node-agent"

# Node agent API (overridable via env)
NODE_AGENT_URL="${NODE_AGENT_URL:-http://localhost:5100}"

# VmState enum — matches VmState in VmModels.cs (index order)
readonly -a VM_STATE_NAMES=(
    "Pending"    # 0
    "Creating"   # 1
    "Starting"   # 2
    "Running"    # 3
    "Paused"     # 4
    "Stopping"   # 5
    "Stopped"    # 6
    "Failed"     # 7
    "NotFound"   # 8
    "Deleted"    # 9
    "Migrating"  # 10
)

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly NC='\033[0m'

# Exit codes
readonly EXIT_SUCCESS=0
readonly EXIT_ERROR=1
readonly EXIT_USAGE=2
readonly EXIT_NO_AUTH=3
readonly EXIT_API_ERROR=4

# ============================================================================
# LOGGING FUNCTIONS
# ============================================================================

log_info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[✓]${NC} $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
log_debug()   { [[ "${DEBUG:-0}" == "1" ]] && echo -e "${CYAN}[DEBUG]${NC} $*" >&2 || true; }

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "This command requires root privileges"
        log_info "Please run with: sudo $SCRIPT_NAME $*"
        exit $EXIT_ERROR
    fi
}

check_dependencies() {
    local missing_deps=()
    for cmd in "$@"; do
        if ! command -v "$cmd" &>/dev/null; then
            missing_deps+=("$cmd")
        fi
    done
    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        log_error "Missing required dependencies: ${missing_deps[*]}"
        return 1
    fi
    return 0
}

check_service_running() {
    if ! systemctl is-active --quiet "$SERVICE_NAME"; then
        return 1
    fi
    return 0
}

check_authenticated() {
    if [[ ! -f "$CREDENTIALS_FILE" ]]; then
        log_error "Node not registered. Run: sudo $SCRIPT_NAME register"
        exit $EXIT_NO_AUTH
    fi
}

get_node_id() {
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        grep "^NODE_ID=" "$CREDENTIALS_FILE" | cut -d= -f2 2>/dev/null || echo ""
    else
        echo ""
    fi
}

get_api_key() {
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        grep "^API_KEY=" "$CREDENTIALS_FILE" | cut -d= -f2 2>/dev/null || echo ""
    else
        echo ""
    fi
}

get_orchestrator_url() {
    _read_setting "orchestrator_url"
}

get_machine_id() {
    if [[ -f /etc/machine-id ]]; then
        cat /etc/machine-id
    else
        log_error "Cannot read /etc/machine-id"
        exit $EXIT_ERROR
    fi
}

# Convert VmState integer to human-readable name
vm_state_name() {
    local idx="${1:-}"
    if [[ "$idx" =~ ^[0-9]+$ ]] && [[ "$idx" -lt "${#VM_STATE_NAMES[@]}" ]]; then
        echo "${VM_STATE_NAMES[$idx]}"
    else
        echo "$idx"  # pass through if it's already a string or unknown
    fi
}

# Human-readable bytes
human_bytes() {
    local bytes="${1:-0}"
    if ! [[ "$bytes" =~ ^[0-9]+$ ]]; then echo "$bytes"; return; fi
    if   (( bytes >= 1073741824 )); then awk "BEGIN {printf \"%.1f GB\", $bytes/1073741824}"
    elif (( bytes >= 1048576 ));    then awk "BEGIN {printf \"%.1f MB\", $bytes/1048576}"
    elif (( bytes >= 1024 ));       then awk "BEGIN {printf \"%.1f KB\", $bytes/1024}"
    else echo "${bytes} B"; fi
}

# ============================================================================
# API FUNCTIONS
# ============================================================================

# Safe API call — never exits on curl error; returns 1 on failure.
# Outputs response body on stdout; HTTP code sent to stderr only in debug mode.
api_call() {
    local method="$1"
    local endpoint="$2"
    local data="${3:-}"
    local url="${NODE_AGENT_URL}${endpoint}"
    local http_code body tmp

    # Use a temp file so we can separate body from http_code without subshell +
    # set -e interaction from arithmetic on a non-numeric string.
    tmp=$(mktemp)

    if [[ -n "$data" ]]; then
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            -H "Content-Type: application/json" \
            -d "$data" \
            --connect-timeout 5 \
            "$url" 2>/dev/null
    else
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            --connect-timeout 5 \
            "$url" 2>/dev/null
    fi
    http_code=$?   # curl exit code first

    # Re-read actual HTTP code from curl's -w output (captured via $())
    # We need a different approach: write http_code to a separate tmp file.
    local code_file
    code_file=$(mktemp)

    if [[ -n "$data" ]]; then
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            -H "Content-Type: application/json" \
            -d "$data" \
            --connect-timeout 5 \
            "$url" 2>/dev/null > "$code_file" || true
    else
        curl -s -o "$tmp" -w "%{http_code}" \
            -X "$method" \
            --connect-timeout 5 \
            "$url" 2>/dev/null > "$code_file" || true
    fi

    http_code=$(cat "$code_file" 2>/dev/null | tr -d '[:space:]' | head -c 3 || echo "0")
    body=$(cat "$tmp" 2>/dev/null || echo "")
    rm -f "$tmp" "$code_file"

    log_debug "API $method $url → HTTP $http_code"

    if [[ "$http_code" =~ ^[0-9]+$ ]] && (( http_code >= 200 && http_code < 300 )); then
        echo "$body"
        return 0
    else
        log_debug "API error (HTTP $http_code): $body"
        return 1
    fi
}

api_get()    { api_call "GET"    "$1"; }
api_post()   { api_call "POST"   "$1" "$2"; }
api_delete() { api_call "DELETE" "$1"; }

# ============================================================================
# INSTALL PARAMS HELPERS
# ============================================================================

# Load install parameters from file into an array
load_install_params() {
    if [[ ! -f "$SETTINGS_FILE" ]]; then
        log_error "No settings file found at $SETTINGS_FILE"
        log_info "Run 'sudo decloud install --orchestrator <url> --wallet <addr>' first"
        exit $EXIT_ERROR
    fi

    local orch wallet
    orch=$(_read_setting "orchestrator_url")
    wallet=$(_read_setting "wallet")

    SAVED_PARAMS=()
    [[ -n "$orch" ]]   && SAVED_PARAMS+=(--orchestrator "$orch")
    [[ -n "$wallet" ]] && SAVED_PARAMS+=(--wallet "$wallet")

    # Infrastructure overrides
    local port wg_port
    port=$(_read_setting "agent_port")
    wg_port=$(_read_setting "wireguard_port")
    [[ -n "$port" ]]    && [[ "$port" != "5100" ]]  && SAVED_PARAMS+=(--port "$port") || true
    [[ -n "$wg_port" ]] && [[ "$wg_port" != "51821" ]] && SAVED_PARAMS+=(--wg-port "$wg_port") || true
}

# Find the node agent install.sh script
find_install_script() {
    local candidates=(
        "$SCRIPT_DIR/install.sh"
        "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/install.sh"
        "/opt/decloud/DeCloud.NodeAgent/install.sh"
        "/opt/decloud/install.sh"
        "/usr/local/share/decloud/install.sh"
    )
    for path in "${candidates[@]}"; do
        if [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    return 1
}

# Fetch a script from the latest GitHub Release.
# Args: <basename> — e.g. "install.sh" or "uninstall.sh"
# Echoes the temp path on success, returns non-zero on failure.
# Trust model: TLS to github.com. install.sh then verifies all release
# artifacts via cosign; uninstall.sh only touches local state.
fetch_release_script() {
    local name="$1"
    local url="https://github.com/bekirmfr/DeCloud.NodeAgent/releases/latest/download/${name}"
    local tmp
    tmp=$(mktemp "/tmp/decloud-${name%.sh}-XXXXXX.sh")
 
    # 30s cap so the command doesn't hang indefinitely on a flaky network.
    if ! curl -fsSL --max-time 30 "$url" -o "$tmp" 2>/dev/null; then
        rm -f "$tmp"
        return 1
    fi
 
    # Sanity check: did we actually get a bash script?
    # An HTML 404 page or empty response would silently break otherwise.
    if ! head -1 "$tmp" 2>/dev/null | grep -qE '^#!.*\b(ba)?sh\b'; then
        rm -f "$tmp"
        return 1
    fi
 
    chmod 755 "$tmp"
    echo "$tmp"
    return 0
}
 
# Locate the on-disk uninstall.sh — mirror of find_install_script.
find_uninstall_script() {
    local candidates=(
        "/usr/local/share/decloud/uninstall.sh"
        "$SCRIPT_DIR/uninstall.sh"
        "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/uninstall.sh"
        "/opt/decloud/DeCloud.NodeAgent/uninstall.sh"
        "/opt/decloud/uninstall.sh"
    )
    for path in "${candidates[@]}"; do
        if [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    return 1
}

cmd_settings() {
    local settings="$SETTINGS_FILE"

    if [[ ! -f "$settings" ]]; then
        log_error "No settings file found at $settings"
        log_info "Run 'sudo $SCRIPT_NAME install' first"
        exit $EXIT_ERROR
    fi

    echo ""
    echo -e "${BOLD}Node Settings${NC} ($settings)"
    echo ""
    jq . "$settings"
    echo ""
}

cmd_configure() {
    check_root

    local country="" region="" zone="" name="" description=""
    local has_locality_change=false
    local has_resource_change=false
    local alloc_mem_percent="" alloc_mem_mb=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --country)     country="$2";     has_locality_change=true; shift 2 ;;
            --region)      region="$2";      has_locality_change=true; shift 2 ;;
            --zone)        zone="$2";        has_locality_change=true; shift 2 ;;
            --name)        name="$2";        shift 2 ;;
            --description) description="$2"; shift 2 ;;
            --allocated-memory-percent)
                alloc_mem_percent="$2"; has_resource_change=true; shift 2 ;;
            --allocated-memory-mb)
                alloc_mem_mb="$2"; has_resource_change=true; shift 2 ;;
            -h|--help)
                echo "Usage: $SCRIPT_NAME configure [options]"
                echo ""
                echo "Locality/rate changes (require logout first):"
                echo "  --country <CC>       ISO 3166-1 alpha-2 country code"
                echo "  --region <region>    DeCloud region code"
                echo "  --zone <zone>        Zone (format: <region>-<n>)"
                echo ""
                echo "Resource allocation (require logout first):"
                echo "  --allocated-memory-percent <1-95>  Percent of physical RAM to offer"
                echo "  --allocated-memory-mb <MB>         Absolute MB of RAM to offer (min 256)"
                echo ""
                echo "Cosmetic changes (allowed anytime):"
                echo "  --name <text>        Node display name"
                echo "  --description <text> Node description"
                echo ""
                echo "After locality or resource changes, run 'decloud register' to commit."
                exit $EXIT_SUCCESS
                ;;
            *)
                log_error "Unknown option: $1"
                exit $EXIT_USAGE
                ;;
        esac
    done

    if [[ -z "$country$region$zone$name$description$alloc_mem_percent$alloc_mem_mb" ]]; then
        log_error "No settings specified"
        echo "Run '$SCRIPT_NAME configure --help' for usage"
        exit $EXIT_USAGE
    fi

    # ── Gate: locality changes require logout ──────────────────────────────
    if $has_locality_change; then
        if [[ -f "$CREDENTIALS_FILE" ]] && [[ ! -f "$CONFIG_DIR/logged-out" ]]; then
            echo ""
            log_error "Cannot change locality while logged in"
            echo ""
            echo "  The full sequence for locality/rate changes:"
            echo "    1. sudo $SCRIPT_NAME logout          # pause scheduling"
            echo "    2. sudo $SCRIPT_NAME configure ...   # change settings"
            echo "    3. sudo $SCRIPT_NAME register        # wallet-sign and commit"
            echo "    4. sudo $SCRIPT_NAME login            # resume when ready"
            echo ""
            exit $EXIT_ERROR
        fi
    fi

    # ── Gate: resource allocation changes require logout ───────────────────
    if $has_resource_change; then
        if [[ -f "$CREDENTIALS_FILE" ]] && [[ ! -f "$CONFIG_DIR/logged-out" ]]; then
            echo ""
            log_error "Cannot change resource allocation while logged in"
            echo ""
            echo "  The full sequence for resource allocation changes:"
            echo "    1. sudo $SCRIPT_NAME logout          # pause scheduling"
            echo "    2. sudo $SCRIPT_NAME configure ...   # change settings"
            echo "    3. sudo $SCRIPT_NAME register        # wallet-sign and commit"
            echo "    4. sudo $SCRIPT_NAME login            # resume when ready"
            echo ""
            exit $EXIT_ERROR
        fi
    fi

    # ── Format validation ─────────────────────────────────────────────────
    if [[ -n "$country" ]]; then
        if [[ ! "$country" =~ ^[A-Z]{2}$ ]]; then
            log_error "Invalid country code: '$country' (must be 2 uppercase letters, e.g. TR, DE, US)"
            exit $EXIT_USAGE
        fi
    fi

    if [[ -n "$region" ]]; then
        if [[ ! "$region" =~ ^[a-z]+(-[a-z]+)*$ ]]; then
            log_error "Invalid region format: '$region' (must be lowercase with hyphens, e.g. eu-east, na-west)"
            exit $EXIT_USAGE
        fi
    fi

    if [[ -n "$zone" ]]; then
        # Zone must start with region prefix
        local expected_region="${region}"
        if [[ -z "$expected_region" ]]; then
            # Read current region from settings JSON
            expected_region=$(_read_setting "region")
        fi
        if [[ -n "$expected_region" ]] && [[ ! "$zone" =~ ^${expected_region}-[1-9][0-9]*$ ]]; then
            log_error "Invalid zone format: '$zone' (must be <region>-<n>, e.g. ${expected_region}-1)"
            exit $EXIT_USAGE
        fi
    fi

    # ── Validate resource allocation flags ─────────────────────────────────
    if [[ -n "$alloc_mem_percent" ]] && [[ -n "$alloc_mem_mb" ]]; then
        log_error "Cannot set both --allocated-memory-percent and --allocated-memory-mb"
        log_info "They are mutually exclusive. Use one or the other."
        exit $EXIT_USAGE
    fi

    if [[ -n "$alloc_mem_percent" ]]; then
        if ! [[ "$alloc_mem_percent" =~ ^[0-9]+$ ]] || \
           [[ "$alloc_mem_percent" -lt 1 ]] || [[ "$alloc_mem_percent" -gt 95 ]]; then
            log_error "Invalid memory percent: '$alloc_mem_percent' (must be 1-95)"
            exit $EXIT_USAGE
        fi
    fi

    if [[ -n "$alloc_mem_mb" ]]; then
        if ! [[ "$alloc_mem_mb" =~ ^[0-9]+$ ]] || [[ "$alloc_mem_mb" -lt 256 ]]; then
            log_error "Invalid memory MB: '$alloc_mem_mb' (must be >= 256)"
            exit $EXIT_USAGE
        fi
    fi

    # ── Apply changes to settings JSON ───────────────────────────────────
    # Read existing params, update the specified ones, write back.
    if [[ ! -f "$SETTINGS_FILE" ]]; then
        log_error "No settings file found — run 'decloud install' first"
        exit $EXIT_ERROR
    fi

    local params_changed=false

    if [[ -n "$country" ]]; then
        _write_setting "country" "$country"
        params_changed=true
        log_success "Country set to: $country"
    fi

    if [[ -n "$region" ]]; then
        _write_setting "region" "$region"
        params_changed=true
        log_success "Region set to: $region"
    fi

    if [[ -n "$zone" ]]; then
        _write_setting "zone" "$zone"
        params_changed=true
        log_success "Zone set to: $zone"
    fi

    if [[ -n "$name" ]]; then
        _write_setting "name" "$name"
        params_changed=true
        log_success "Name set to: $name"
    fi

    if [[ -n "$description" ]]; then
        _write_setting "description" "$description"
        params_changed=true
        log_success "Description set to: $description"
    fi

    # ── Resource allocation writes ──────────────────────────────────────
    if [[ -n "$alloc_mem_percent" ]]; then
        local tmp; tmp=$(mktemp)
        jq '.resources.memory = {"mode":"percent","value":'"$alloc_mem_percent"'}' \
            "$SETTINGS_FILE" > "$tmp" && mv "$tmp" "$SETTINGS_FILE"
        chmod 600 "$SETTINGS_FILE"
        params_changed=true
        log_success "Memory allocation set to: ${alloc_mem_percent}%"
    fi

    if [[ -n "$alloc_mem_mb" ]]; then
        local tmp; tmp=$(mktemp)
        jq '.resources.memory = {"mode":"mb","value":'"$alloc_mem_mb"'}' \
            "$SETTINGS_FILE" > "$tmp" && mv "$tmp" "$SETTINGS_FILE"
        chmod 600 "$SETTINGS_FILE"
        params_changed=true
        log_success "Memory allocation set to: ${alloc_mem_mb} MB"
    fi

    # Sync settings.json → appsettings.Production.json so the running
    # agent sees the new values. Without this, the agent reads stale
    # defaults from appsettings and the heartbeat hash mismatches.
    if $params_changed; then
        local appsettings="$PUBLISH_DIR/appsettings.Production.json"
        if [[ -f "$appsettings" ]]; then
            # Read resource allocation from settings.json
            local mem_mode mem_value
            mem_mode=$(jq -r '.resources.memory.mode // empty' "$SETTINGS_FILE" 2>/dev/null)
            mem_value=$(jq -r '.resources.memory.value // empty' "$SETTINGS_FILE" 2>/dev/null)

            local tmp_ap; tmp_ap=$(mktemp)
            jq --arg c "$(_read_setting "country" || echo "ZZ")" \
               --arg r "$(_read_setting "region" || echo "default")" \
               --arg z "$(_read_setting "zone" || echo "default")" \
               --arg n "$(_read_setting "name" || echo "$(hostname)")" \
               --arg mm "${mem_mode}" \
               --arg mv "${mem_value}" \
               '.Node.Country = $c | .Node.Region = $r | .Node.Zone = $z | .Node.Name = $n |
                if $mm != "" then .Node.Resources.Memory.Mode = $mm | .Node.Resources.Memory.Value = ($mv | tonumber) else . end' \
               "$appsettings" > "$tmp_ap" && mv "$tmp_ap" "$appsettings"
            chmod 640 "$appsettings"
        fi

        # Restart agent to pick up new appsettings
        if check_service_running; then
            systemctl restart "$SERVICE_NAME" 2>/dev/null || true
            log_info "Agent restarted to apply new settings"
        fi
    fi

    if $params_changed; then
        echo ""
        if $has_locality_change; then
            log_info "Settings updated locally. Run 'sudo $SCRIPT_NAME register' to commit to orchestrator."
        else
            log_info "Settings updated."

            # Push cosmetic changes to orchestrator if enrolled
            if [[ -f "$CREDENTIALS_FILE" ]]; then
                local api_key; api_key=$(get_api_key)
                local orchestrator_url; orchestrator_url=$(get_orchestrator_url)

                if [[ -n "$orchestrator_url" && -n "$api_key" ]]; then
                    local payload="{}"
                    [[ -n "$name" ]]        && payload=$(echo "$payload" | jq --arg v "$name" '.name = $v')
                    [[ -n "$description" ]] && payload=$(echo "$payload" | jq --arg v "$description" '.description = $v')

                    local http_code
                    http_code=$(curl -s -o /dev/null -w "%{http_code}" \
                        -X PATCH \
                        -H "Authorization: Bearer $api_key" \
                        -H "Content-Type: application/json" \
                        -d "$payload" \
                        --connect-timeout 10 \
                        "${orchestrator_url}/api/nodes/me/profile" 2>/dev/null || echo "0")

                    if [[ "$http_code" =~ ^2 ]]; then
                        log_success "Profile updated on orchestrator"
                    else
                        log_warn "Could not push profile to orchestrator (HTTP $http_code)"
                        log_info "Changes saved locally — will take effect on next register"
                    fi
                fi
            fi
        fi
    fi
}

# Read a single field from settings.json.
_read_setting() {
    local key="$1"
    if [[ -f "$SETTINGS_FILE" ]]; then
        jq -r --arg k "$key" '.[$k] // empty' "$SETTINGS_FILE" 2>/dev/null
    fi
}

# Write a single field to settings.json.
# Creates the file with version:1 if it doesn't exist.
_write_setting() {
    local key="$1"
    local value="$2"

    if [[ ! -f "$SETTINGS_FILE" ]]; then
        echo '{"version":1}' > "$SETTINGS_FILE"
        chmod 600 "$SETTINGS_FILE"
    fi

    local tmp; tmp=$(mktemp)
    jq --arg v "$value" ".[\"${key}\"] = \$v" "$SETTINGS_FILE" > "$tmp" \
        && mv "$tmp" "$SETTINGS_FILE"
    chmod 600 "$SETTINGS_FILE"
}

# ============================================================================
# AUTHENTICATION COMMANDS
# ============================================================================

cmd_register() {
    check_root

    # cli-decloud-node handles the full auth flow:
    #   wallet address prompt → signing message → QR code → sign.html URL
    #   → signature input → local verification → writes /etc/decloud/pending-auth as JSON
    # AuthenticationManager then reads that JSON and registers with the orchestrator,
    # writing /etc/decloud/credentials on success.
    local wallet_cli="/usr/local/bin/cli-decloud-node"
    if [[ ! -x "$wallet_cli" ]]; then
        log_error "Authentication CLI not found at $wallet_cli"
        log_info "Run 'sudo $SCRIPT_NAME update' to reinstall"
        exit $EXIT_ERROR
    fi

    # Ensure service is running so AuthenticationManager can pick up pending-auth
    if ! check_service_running; then
        log_warn "Node agent service is not running — starting it..."
        systemctl start "$SERVICE_NAME" || {
            log_error "Failed to start service"
            exit $EXIT_ERROR
        }
        sleep 2
    fi

    # Already authenticated?
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        local node_id; node_id=$(get_node_id)
        log_warn "Node is already registered (Node ID: $node_id)"
        read -rp "Re-register? This will re-register the node with new settings. [y/N]: " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            log_info "Registration cancelled"
            exit $EXIT_SUCCESS
        fi
        rm -f "$CREDENTIALS_FILE"
    fi

    # Remove any stale pending-auth before starting
    rm -f "$PENDING_AUTH_FILE"

    # Clear logged-out sentinel — re-registration implies intent to become active
    rm -f "$CONFIG_DIR/logged-out"

    # ── Step 1: run cli-decloud-node register ───────────────────────────────
    # This prompts for wallet, shows QR code, waits for signature,
    # verifies it locally, and writes the JSON pending-auth file.
    "$wallet_cli" register
    local cli_exit=$?

    if (( cli_exit != 0 )); then
        log_error "Authentication cancelled or failed"
        exit $EXIT_ERROR
    fi

    # Confirm the JSON pending-auth file was actually written
    if [[ ! -f "$PENDING_AUTH_FILE" ]]; then
        log_error "Pending auth file not written — authentication may have failed"
        exit $EXIT_ERROR
    fi

    # ── Step 2: wait for AuthenticationManager to complete registration ─────
    echo ""
    log_info "Waiting for node agent to complete registration..."
    echo ""

    local timeout=120
    local elapsed=0
    local interval=3

    while (( elapsed < timeout )); do
        if [[ -f "$CREDENTIALS_FILE" ]]; then
            local node_id; node_id=$(get_node_id)
            echo ""
            echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
            echo -e "${BOLD}  ✓ Registration Complete!${NC}"
            echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
            echo ""
            echo "  Node ID: $node_id"
            echo ""
            log_info "Run '$SCRIPT_NAME status' to check node status"
            echo ""
            return 0
        fi

        printf "  Waiting for agent registration... (%ds/%ds)\r" "$elapsed" "$timeout"
        sleep $interval
        (( elapsed += interval ))
    done

    echo ""
    log_error "Registration timed out after ${timeout}s"
    log_info "The signature was saved. Check agent logs to see why registration failed:"
    log_info "  $SCRIPT_NAME logs --journal -n 50"
    exit $EXIT_ERROR
}

cmd_login() {
    check_root

    # Must be enrolled (credentials exist)
    if [[ ! -f "$CREDENTIALS_FILE" ]]; then
        log_error "Node is not registered — no credentials found"
        echo ""
        echo "  To register this node (wallet ceremony):"
        echo "    sudo $SCRIPT_NAME register"
        echo ""
        exit $EXIT_NO_AUTH
    fi

    local node_id; node_id=$(get_node_id)
    local api_key; api_key=$(get_api_key)
    local orchestrator_url; orchestrator_url=$(get_orchestrator_url)

    if [[ -z "$node_id" || -z "$api_key" || -z "$orchestrator_url" ]]; then
        log_error "Credentials file is incomplete — re-register"
        log_info "  sudo $SCRIPT_NAME register"
        exit $EXIT_ERROR
    fi

    log_info "Logging in node $node_id..."

    local response http_code body
    local tmp; tmp=$(mktemp)
    local code_file; code_file=$(mktemp)

    curl -s -o "$tmp" -w "%{http_code}" \
        -X POST \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        --connect-timeout 10 \
        "${orchestrator_url}/api/nodes/${node_id}/login" \
        2>/dev/null > "$code_file" || true

    http_code=$(cat "$code_file" 2>/dev/null | tr -d '[:space:]' | head -c 3 || echo "0")
    body=$(cat "$tmp" 2>/dev/null || echo "")
    rm -f "$tmp" "$code_file"

    if [[ "$http_code" =~ ^2 ]]; then
        # Remove logged-out sentinel
        rm -f "$CONFIG_DIR/logged-out"

        echo ""
        log_success "Node logged in — scheduling resumed"
        echo ""

        # Check for drift warning in response
        local drift_warning
        drift_warning=$(echo "$body" | jq -r '.data.settingsDriftWarning // empty' 2>/dev/null)
        if [[ -n "$drift_warning" ]]; then
            log_warn "Settings drift detected: $drift_warning"
            log_info "Run 'sudo $SCRIPT_NAME register' to re-commit settings"
        fi
    else
        log_error "Login failed (HTTP $http_code)"
        echo "$body" | jq -r '.error // .message // .' 2>/dev/null || echo "$body"
        exit $EXIT_ERROR
    fi
}

cmd_logout() {
    check_root

    # Check if already logged out
    if [[ -f "$CONFIG_DIR/logged-out" ]]; then
        log_info "Node is already logged out (scheduling paused)"
        return 0
    fi

    # Must be enrolled
    if [[ ! -f "$CREDENTIALS_FILE" ]]; then
        log_info "Node is not registered — nothing to log out from"
        return 0
    fi

    local node_id; node_id=$(get_node_id)
    local api_key; api_key=$(get_api_key)
    local orchestrator_url; orchestrator_url=$(get_orchestrator_url)

    if [[ -z "$orchestrator_url" ]]; then
        log_warn "Cannot determine orchestrator URL — writing sentinel only"
        touch "$CONFIG_DIR/logged-out"
        chmod 600 "$CONFIG_DIR/logged-out"
        log_success "Node logged out (local only — orchestrator not notified)"
        return 0
    fi

    log_info "Logging out node $node_id..."

    local response http_code body
    local tmp; tmp=$(mktemp)
    local code_file; code_file=$(mktemp)

    curl -s -o "$tmp" -w "%{http_code}" \
        -X POST \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        --connect-timeout 10 \
        "${orchestrator_url}/api/nodes/${node_id}/logout" \
        2>/dev/null > "$code_file" || true

    http_code=$(cat "$code_file" 2>/dev/null | tr -d '[:space:]' | head -c 3 || echo "0")
    body=$(cat "$tmp" 2>/dev/null || echo "")
    rm -f "$tmp" "$code_file"

    # Write sentinel regardless of API response — operator intent is clear
    touch "$CONFIG_DIR/logged-out"
    chmod 600 "$CONFIG_DIR/logged-out"

    if [[ "$http_code" =~ ^2 ]]; then
        local active_vms
        active_vms=$(echo "$body" | jq -r '.data.activeVmCount // 0' 2>/dev/null)

        echo ""
        log_success "Node logged out — scheduling paused"

        if [[ "$active_vms" -gt 0 ]]; then
            echo ""
            log_info "$active_vms VM(s) still running on this node."
            log_info "Existing VMs continue operating — only new scheduling is paused."
            echo ""
            echo "  To change locality/rate settings:"
            echo "    sudo $SCRIPT_NAME configure --country BR --region sa-east"
            echo "    sudo $SCRIPT_NAME register"
            echo "    sudo $SCRIPT_NAME login"
            echo ""
            echo "  To resume scheduling without changes:"
            echo "    sudo $SCRIPT_NAME login"
        fi
    else
        log_warn "Orchestrator notification failed (HTTP $http_code) — logged out locally"
        log_info "The orchestrator will detect the pause via heartbeat"
    fi

    echo ""
}

