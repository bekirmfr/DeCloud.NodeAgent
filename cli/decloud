cmd_reset() {
    check_root

    local force=false keep_vms=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)    force=true;    shift ;;
            --keep-vms) keep_vms=true; shift ;;
            *)          shift ;;
        esac
    done

    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  ⚠️  DESTRUCTIVE OPERATION — NODE RESET${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}This will:${NC}"
    echo "  1. Stop the node agent service"
    echo "  2. Remove authentication credentials"
    echo "  3. Clear all node agent logs"
    if ! $keep_vms; then
        echo "  4. Delete ALL virtual machines and their data"
    else
        echo "  4. Keep VMs intact (--keep-vms)"
    fi
    echo "  5. Restart the node agent service"
    echo ""
    echo -e "${RED}WARNING: IRREVERSIBLE!${NC}"
    echo ""

    if ! $force; then
        read -rp "Type 'RESET' to confirm: " confirmation
        [[ "$confirmation" == "RESET" ]] || { log_info "Reset cancelled"; exit $EXIT_SUCCESS; }
    fi

    echo ""
    log_info "Starting node reset..."
    echo ""

    # Temporarily disable errexit so we continue even if individual steps fail
    set +e

    log_info "[1/5] Stopping service..."
    systemctl stop "$SERVICE_NAME" 2>/dev/null && log_success "Stopped" || log_warn "Was not running"
    sleep 2

    log_info "[2/5] Removing credentials..."
    rm -f "$CREDENTIALS_FILE" "$PENDING_AUTH_FILE"
    log_success "Credentials removed"

    log_info "[3/5] Clearing logs..."
    if [[ -d "$LOG_DIR" ]]; then
        find "$LOG_DIR" -type f -name "*.log" -delete 2>/dev/null || true
    fi
    # Rotate and vacuum only this service's journal entries safely via size limit
    journalctl --rotate >/dev/null 2>&1 || true
    journalctl -u "$SERVICE_NAME" --vacuum-size=1K >/dev/null 2>&1 || true
    log_success "Logs cleared"

    log_info "[4/5] Cleaning VMs..."
    if ! $keep_vms; then
        if command -v virsh &>/dev/null; then
            local vms
            mapfile -t vms < <(virsh list --all --name 2>/dev/null | grep -v '^$' || true)
            for v in "${vms[@]}"; do
                virsh destroy  "$v" 2>/dev/null || true
                virsh undefine "$v" --remove-all-storage 2>/dev/null || true
            done
            [[ -d "$VM_STORAGE_PATH" ]] && rm -rf "${VM_STORAGE_PATH:?}"/* 2>/dev/null || true
            log_success "All VMs removed (${#vms[@]} VMs)"
        else
            log_warn "virsh not found — skipping VM cleanup"
        fi
    else
        log_info "Skipped (--keep-vms)"
    fi

    log_info "[5/5] Restarting service..."
    if systemctl start "$SERVICE_NAME" 2>/dev/null; then
        sleep 3
        systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null \
            && log_success "Service restarted" \
            || log_error "Service failed to start — check: journalctl -u $SERVICE_NAME -n 50"
    else
        log_error "Failed to restart — try: sudo systemctl start $SERVICE_NAME"
    fi

    set -e

    echo ""
    echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Reset Complete${NC}"
    echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    echo "Next steps:"
    echo "  1. Re-authenticate: ${BOLD}sudo $SCRIPT_NAME login${NC}"
    echo "  2. Check status:    ${BOLD}$SCRIPT_NAME status${NC}"
    echo ""
}

cmd_logs() {
    # Defaults
    local subcommand=""
    local lines=50
    local follow=false
    local source="file"

    # Check if first arg is a subcommand word (not a flag)
    if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
        subcommand="$1"
        shift
    fi

    case "$subcommand" in
        clear|empty)
            cmd_logs_clear "$@"
            return
            ;;
        view|"")
            ;;  # continue to view
        *)
            log_error "Unknown logs subcommand: $subcommand"
            echo "Usage: $SCRIPT_NAME logs [view|clear] [-f] [-n <lines>] [--journal]"
            exit $EXIT_USAGE
            ;;
    esac

    # Parse view options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--follow)  follow=true;   shift ;;
            -n|--lines)   lines="$2";    shift 2 ;;
            --journal)    source="journal"; shift ;;
            --file)       source="file";    shift ;;
            *)            shift ;;
        esac
    done

    if [[ "$source" == "journal" ]]; then
        if $follow; then
            exec journalctl -u "$SERVICE_NAME" -f
        else
            exec journalctl -u "$SERVICE_NAME" -n "$lines" --no-pager
        fi
    else
        if [[ ! -f "$LOG_FILE" ]]; then
            log_warn "Log file not found: $LOG_FILE"
            echo "The service may be logging via systemd journal. Try:"
            echo "  $SCRIPT_NAME logs --journal"
            exit $EXIT_ERROR
        fi
        if $follow; then
            exec tail -f "$LOG_FILE"
        else
            exec tail -n "$lines" "$LOG_FILE"
        fi
    fi
}

cmd_logs_clear() {
    check_root

    local before_last_start=false force=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --before-last-start) before_last_start=true; shift ;;
            --force)             force=true;             shift ;;
            *)                   shift ;;
        esac
    done

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    $before_last_start \
        && echo -e "${BOLD}  Clear Logs Before Last Service Start${NC}" \
        || echo -e "${BOLD}  Clear All Node Agent Logs${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    if ! $force; then
        $before_last_start \
            && read -rp "Clear logs before last start? [y/N]: " confirm \
            || read -rp "Clear ALL logs? [y/N]: " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { log_info "Cancelled"; exit $EXIT_SUCCESS; }
    fi

    set +e

    if $before_last_start; then
        # Get last start time and vacuum entries older than that window
        local last_start last_epoch now_epoch time_diff
        last_start=$(systemctl show -p ActiveEnterTimestamp "$SERVICE_NAME" | cut -d= -f2)
        if [[ -z "$last_start" || "$last_start" == "0" ]]; then
            log_warn "Could not determine last service start time"
            set -e; exit $EXIT_ERROR
        fi
        last_epoch=$(date -d "$last_start" +%s 2>/dev/null || echo 0)
        now_epoch=$(date +%s)
        time_diff=$(( now_epoch - last_epoch ))
        if (( time_diff > 0 )); then
            journalctl --rotate >/dev/null 2>&1 || true
            # --vacuum-time applies globally; filter to this service after vacuum
            # Use --vacuum-size on the global journal to avoid nuking unrelated services.
            # The correct scoped approach is to truncate the file log only.
            log_info "Clearing file-based logs (journal entries preserved)..."
            [[ -f "$LOG_FILE" ]] && > "$LOG_FILE" && log_success "Log file cleared" || true
            log_info "Journal entries are not trimmed by service with --before-last-start"
            log_info "Use '$SCRIPT_NAME logs clear' to clear journal too"
        fi
    else
        # Clear file logs
        log_info "[1/3] Clearing log file..."
        if [[ -f "$LOG_FILE" ]]; then
            local sz; sz=$(du -h "$LOG_FILE" 2>/dev/null | cut -f1 || echo "?")
            > "$LOG_FILE" && log_success "Cleared $LOG_FILE (was $sz)" || log_warn "Could not clear $LOG_FILE"
        fi

        # Clear rotated log files
        log_info "[2/3] Clearing rotated log files..."
        local n=0
        while IFS= read -r -d '' f; do
            rm -f "$f" 2>/dev/null && (( n++ )) || true
        done < <(find "$LOG_DIR" -type f \( -name "*.log.*" -o -name "audit.log*" \) -print0 2>/dev/null)
        (( n > 0 )) && log_success "Removed $n rotated file(s)" || log_info "No rotated files found"

        # Rotate + vacuum service journal using --vacuum-size (safe — reduces to 1KB,
        # does NOT affect other services' journal files).
        log_info "[3/3] Clearing systemd journal for $SERVICE_NAME..."
        journalctl --rotate >/dev/null 2>&1 || true
        journalctl -u "$SERVICE_NAME" --vacuum-size=1K >/dev/null 2>&1 \
            && log_success "Journal cleared for $SERVICE_NAME" \
            || log_warn "Could not vacuum journal (may need elevated privileges)"
    fi

    set -e

    echo ""
    echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Log Clearing Complete${NC}"
    echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    echo "View current logs: ${BOLD}$SCRIPT_NAME logs${NC}"
    echo "Follow logs:       ${BOLD}$SCRIPT_NAME logs -f${NC}"
    echo ""
}

# ============================================================================
# DIAGNOSTIC COMMANDS
# ============================================================================

cmd_diagnose() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  DeCloud Node Agent Diagnostics${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    echo -e "${BOLD}1. Service Status${NC}"
    if check_service_running; then
        log_success "Service is running"
    else
        log_error "Service is not running"
        echo "  Start with: sudo $SCRIPT_NAME start"
    fi
    echo ""

    echo -e "${BOLD}2. Authentication${NC}"
    if [[ -f "$CREDENTIALS_FILE" ]]; then
        log_success "Credentials file exists"
        local node_id; node_id=$(get_node_id)
        [[ -n "$node_id" ]] && echo "  Node ID: $node_id" || log_warn "Node ID not found in credentials"
    else
        log_error "Not authenticated — run: sudo $SCRIPT_NAME login"
    fi
    echo ""

    echo -e "${BOLD}3. Virtualization (libvirt)${NC}"
    if command -v virsh &>/dev/null; then
        log_success "virsh available"
        if systemctl is-active --quiet libvirtd 2>/dev/null; then
            log_success "libvirtd running"
        else
            log_error "libvirtd not running — sudo systemctl start libvirtd"
        fi
        local vm_count; vm_count=$(virsh list --all --name 2>/dev/null | grep -c . || echo 0)
        echo "  VMs in libvirt: $vm_count"
    else
        log_error "virsh not found (libvirt not installed)"
    fi
    echo ""

    echo -e "${BOLD}4. WireGuard${NC}"
    if command -v wg &>/dev/null; then
        log_success "wg available"
        local interfaces
        if interfaces=$(wg show interfaces 2>/dev/null); then
            [[ -n "$interfaces" ]] && { log_success "Active interfaces: $interfaces"; } || log_warn "No WireGuard interfaces active"
        else
            log_warn "Cannot query WireGuard (may need root)"
        fi
    else
        log_warn "WireGuard not installed"
    fi
    echo ""

    echo -e "${BOLD}5. Network Connectivity${NC}"
    if check_service_running && [[ -f "$CREDENTIALS_FILE" ]]; then
        local status internet orchestrator
        if status=$(api_get "/api/node/network/status" 2>/dev/null); then
            internet=$(echo     "$status" | jq -r '.isInternetReachable    // "unknown"' 2>/dev/null)
            orchestrator=$(echo "$status" | jq -r '.isOrchestratorReachable // "unknown"' 2>/dev/null)
            [[ "$internet"     == "true" ]] && log_success "Internet reachable"     || log_error "Internet unreachable"
            [[ "$orchestrator" == "true" ]] && log_success "Orchestrator reachable" || log_error "Orchestrator unreachable"
        else
            log_warn "Cannot check (API not responding)"
        fi
    else
        log_warn "Skipped (service not running or not authenticated)"
    fi
    echo ""

    echo -e "${BOLD}6. Disk Space${NC}"
    if [[ -d "$VM_STORAGE_PATH" ]]; then
        local usage available pct
        usage=$(df -h "$VM_STORAGE_PATH" | awk 'NR==2{print $5}')
        available=$(df -h "$VM_STORAGE_PATH" | awk 'NR==2{print $4}')
        pct=$(echo "$usage" | tr -d '%')
        echo "  VM Storage: $usage used, $available available"
        (( pct > 80 )) && log_warn "Disk usage high (${usage})" || log_success "Disk space OK"
    else
        log_warn "VM storage directory not found: $VM_STORAGE_PATH"
    fi
    echo ""

    echo -e "${BOLD}7. Recent Errors${NC}"
    local err_count
    err_count=$(journalctl -u "$SERVICE_NAME" --since "10 minutes ago" -p err --no-pager -q 2>/dev/null | grep -c . || echo 0)
    if (( err_count > 0 )); then
        log_warn "$err_count error(s) in last 10 minutes — check: $SCRIPT_NAME logs -n 50"
    else
        log_success "No recent errors"
    fi
    echo ""
}

cmd_test_api() {
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Node Agent API Test${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    local endpoints=(
        "/health"
        "/api/node"
        "/api/node/cpu"
        "/api/node/memory"
        "/api/node/storage"
    )

    for ep in "${endpoints[@]}"; do
        printf "  Testing %-30s " "$ep..."
        local response
        if response=$(api_get "$ep" 2>/dev/null); then
            log_success "OK"
            [[ "${VERBOSE:-0}" == "1" ]] && echo "$response" | jq -C '.' 2>/dev/null || true
        else
            log_error "FAILED"
        fi
    done
    echo ""
}

