cmd_vm_list() {
    check_authenticated
    if ! check_service_running; then log_error "Service not running"; exit $EXIT_ERROR; fi

    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  Virtual Machines${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""

    local vms
    if vms=$(api_get "/api/vms" 2>/dev/null); then
        local count; count=$(echo "$vms" | jq -r 'length' 2>/dev/null || echo 0)
        if (( count == 0 )); then
            log_info "No VMs found"
        else
            # Build friendly table: map state integer to name, bytes to human-readable
            echo "$vms" | jq -r '.[] | [
                .vmId,
                (.name // "-"),
                (.state | tostring),
                ((.spec.virtualCpuCores // 0) | tostring),
                ((.spec.memoryBytes     // 0) | tostring)
            ] | @tsv' 2>/dev/null | while IFS=$'\t' read -r vmid name state cpus membytes; do
                local state_name mem_hr
                state_name=$(vm_state_name "$state")
                mem_hr=$(human_bytes "$membytes")
                printf "%-38s  %-24s  %-10s  %s vCPU  %s\n" "$vmid" "$name" "$state_name" "$cpus" "$mem_hr"
            done | (
                echo -e "${BOLD}VM ID                                   NAME                      STATE       CPU        MEMORY${NC}"
                echo    "──────────────────────────────────────  ────────────────────────  ──────────  ─────────  ──────────"
                cat
            )
        fi
    else
        log_error "Failed to fetch VM list"; exit $EXIT_API_ERROR
    fi
    echo ""
}

