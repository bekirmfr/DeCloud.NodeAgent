/* Version script for DeCloud cuBLAS stub library.
 *
 * Exports cuBLAS symbols under the libcublas.so.12 version namespace.
 * Required by both ggml (cublasCreate_v2@libcublas.so.12) and PyTorch
 * (cublasDgemm_v2, cublasHgemm, cublasGetVersion_v2, etc.).
 *
 * See: GPU_PROXY_DEBUGGING_JOURNAL.md, Problem 17 (Day 4)
 */
libcublas.so.12 {
    global:
        /* Handle management */
        cublasCreate_v2;
        cublasDestroy_v2;
        cublasSetStream_v2;
        cublasSetMathMode;
        cublasGetMathMode;
        cublasGetStatusString;
        cublasGetVersion_v2;
        cublasSetWorkspace_v2;

        /* Logging (CUDA 12+) */
        cublasLoggerConfigure;
        cublasSetLoggerCallback;

        /* FP32 GEMM */
        cublasSgemm_v2;
        cublasSgemmStridedBatched;

        /* FP64 GEMM */
        cublasDgemm_v2;
        cublasDgemmStridedBatched;

        /* FP16 GEMM */
        cublasHgemm;

        /* Typed GEMM (Ex variants — RPC proxied) */
        cublasGemmEx;
        cublasGemmStridedBatchedEx;
        cublasGemmBatchedEx;

        /* TRSM */
        cublasStrsmBatched;
    local:
        *;
};
