@echo off
setlocal

:: ============================================================
:: DeCloud Node Agent - Windows WSL Setup
:: Double-click to install. Run as Administrator.
:: ============================================================

:: Self-elevate if not already admin
net session >nul 2>&1
if %errorlevel% equ 0 goto :ALREADY_ADMIN

echo.
echo  [DeCloud] Requesting administrator privileges...
echo  A UAC prompt will appear - click Yes to continue.
echo.
powershell -NoProfile -Command "Start-Process cmd -ArgumentList '/c ""%~f0""' -Verb RunAs -Wait"
exit /b %errorlevel%

:ALREADY_ADMIN

:: Extract and run the embedded PowerShell installer.
:: The payload is a base64-encoded PS script stored after the __PAYLOAD__ marker.
:: We read it from this file, decode it, write to a temp .ps1, and execute it.
powershell -NoProfile -ExecutionPolicy Bypass -Command "$f=Get-Content -LiteralPath '%~f0' -Encoding UTF8; $mk=$f|Select-String '^::__PAYLOAD__'|Select-Object -First 1; if(-not $mk){Write-Host '[ERR] Payload not found.' -ForegroundColor Red;exit 1}; $b64=($f[$mk.LineNumber..($f.Length-1)] -join '').Trim(); $bytes=[Convert]::FromBase64String($b64); $src=[System.Text.Encoding]::UTF8.GetString($bytes); $tmp=[IO.Path]::GetTempFileName()+'.ps1'; Set-Content -Path $tmp -Value $src -Encoding UTF8; try{& powershell -NoProfile -ExecutionPolicy Bypass -File $tmp}finally{Remove-Item $tmp -Force -ErrorAction SilentlyContinue}"
exit /b %errorlevel%

::__PAYLOAD__

